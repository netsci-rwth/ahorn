                                      : "inset-x-0",
                                ]}
                              />
                            )}
                            <span
                              class:list={[
                                "relative z-10 rounded-full",
                                isActive
                                  ? "size-3.5 bg-blue-100 ring-2 ring-white dark:bg-blue-50 dark:ring-black-100"
                                  : "size-2 bg-black-25 dark:bg-black-75",
                              ]}
                            />
