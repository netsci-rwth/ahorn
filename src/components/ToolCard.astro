---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import Icon from "@/components/Icon.astro";
import { faDownload } from "@fortawesome/free-solid-svg-icons";
import { surfaceClassName } from "@/components/surface-styles";

interface Props {
  tool: CollectionEntry<"tools">;
}

const { tool } = Astro.props;
const { Content } = await render(tool);
const { data } = tool;
const isAccessMethod = data.section === "start";
const isPrimary = isAccessMethod || data.section === "integration";
const hasContent = Boolean(tool.body?.trim());
const externalAttributes = data.external
  ? { target: "_blank" }
  : {};

const cardClassName = surfaceClassName({
  variant: isPrimary ? "primary" : "secondary",
  class: isAccessMethod
    ? "min-w-0 p-4 sm:p-5"
    : "group relative h-full max-w-full min-w-0 p-4 sm:p-5",
});
---

<article class={cardClassName}>
  {isAccessMethod ? (
    <header class="flex min-w-0 items-start gap-3">
      <span class="mt-0.5 flex size-8 shrink-0 items-center justify-center rounded-md border border-black-25 bg-white text-blue-100 dark:border-black-75 dark:bg-black-100/80 dark:text-blue-50">
        {data.icon === "download" && <Icon icon={faDownload} class="size-3.5" />}
      </span>
      <div class="min-w-0 flex-1">
        <div class="flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1">
          <h3 class="text-sm font-semibold text-black-100 dark:text-white">{data.name}</h3>
          {data.label && <span class="text-xs font-medium wrap-break-word text-black-50 dark:text-black-50">{data.label}</span>}
        </div>
        <p class="mt-1 text-sm leading-6 text-black-75 dark:text-black-25">{data.description}</p>
      </div>
      <a
        href={data.href}
        {...externalAttributes}
        class="min-h-8 shrink-0 rounded-lg border border-black-25 bg-white px-2.5 py-1 text-xs font-medium text-black-100 no-underline transition-colors hover:border-black-50 hover:bg-black-10 dark:border-black-75 dark:bg-black-100 dark:text-white dark:hover:border-black-50 dark:hover:bg-black-90"
      >
        {data.actionLabel}
      </a>
    </header>
  ) : (
    <>
      <a
        href={data.href}
        {...externalAttributes}
        aria-label={`${data.actionLabel} ${data.name} project`}
        class="absolute top-4 right-4 min-h-8 shrink-0 rounded-lg border border-black-25 bg-white px-2.5 py-1 text-xs font-medium text-black-100 no-underline transition-colors hover:border-black-50 hover:bg-black-10 dark:border-black-75 dark:bg-black-100 dark:text-white dark:hover:border-black-50 dark:hover:bg-black-90 sm:top-5 sm:right-5"
      >
        {data.actionLabel}
      </a>
      <header class="flex min-w-0 gap-3 pr-24 sm:gap-4">
        {data.logo ? (
          <span class="flex size-10 shrink-0 items-center justify-center rounded-md border border-black-25 bg-white p-1.5 dark:border-black-75">
            <img src={data.logo} alt="" width="40" height="40" class="max-h-7 object-contain" />
          </span>
        ) : (
          <span class="flex size-10 shrink-0 items-center justify-center rounded-md border border-black-25 bg-black-10 text-[11px] font-semibold tracking-wide text-black-75 uppercase dark:border-black-75 dark:bg-black-100 dark:text-black-25">
            {data.name.slice(0, 3)}
          </span>
        )}
        <div class="min-w-0 flex-1">
          <h3 class="text-base font-semibold tracking-tight text-black-100 dark:text-white">{data.name}</h3>
          <p class="mt-1 text-sm leading-6 text-black-75 dark:text-black-25">{data.description}</p>
        </div>
      </header>
    </>
  )}

  {hasContent && <div class="mt-4 max-w-none text-sm leading-6 text-black-75 dark:text-black-25 prose dark:prose-invert"><Content /></div>}
</article>
