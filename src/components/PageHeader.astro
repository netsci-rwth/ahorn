---
interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  class?: string;
}

const {
  title,
  eyebrow,
  description,
  class: classValue,
} = Astro.props;
const hasEyebrow = Boolean(eyebrow) || Astro.slots.has("eyebrow");
const hasActions = Astro.slots.has("actions");
---

<section
  class:list={[
    "relative left-1/2 isolate ml-[-50vw] w-screen max-w-[100vw] overflow-hidden border-b border-black-25 py-8 sm:py-10 dark:border-black-75",
    classValue,
  ]}
>
  <div
    aria-hidden="true"
    class="absolute inset-x-0 -top-48 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-60"
  >
    <div
      style={{
        clipPath:
          "polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)",
      }}
      class="relative left-[calc(50%+10rem)] aspect-1155/678 w-lg -translate-x-1/2 rotate-30 bg-linear-to-tr from-blue-50 to-blue-100 opacity-18 sm:left-[calc(50%+18rem)] sm:w-240 dark:opacity-12"
    >
    </div>
  </div>

  <div
    class="mx-auto w-full max-w-7xl min-w-0 px-4 sm:px-6 lg:px-8"
  >
    <div class="grid min-w-0 gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-10">
      <div class="max-w-4xl min-w-0">
        {hasEyebrow && (
          <div class="min-w-0 text-sm font-semibold tracking-widest wrap-break-word text-blue-100 uppercase">
            <slot name="eyebrow">{eyebrow}</slot>
          </div>
        )}
        <h1 class="mt-2 text-3xl font-semibold tracking-tight wrap-break-word text-black-100 sm:text-4xl dark:text-white">
          {title}
        </h1>
        {description && (
          <p class="mt-4 max-w-3xl text-base leading-7 wrap-break-word text-black-75 dark:text-black-25">
            {description}
          </p>
        )}
      </div>
      {hasActions && (
        <div class="w-full min-w-0 self-start lg:w-auto lg:max-w-[min(42vw,30rem)] lg:shrink-0">
          <slot name="actions" />
        </div>
      )}
    </div>
    <slot />
  </div>
</section>
