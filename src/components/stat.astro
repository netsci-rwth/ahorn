---
import StatisticsBlock from "@/components/statistics-block.astro";
import type { SurfaceVariant } from "@/components/surface-styles";

interface Props {
  title: string;
  value: string | number;
  description?: string;
  variant?: SurfaceVariant;
  class?: string;
}

const {
  title,
  value,
  description,
  variant = "primary",
  class: classValue,
} = Astro.props;
---

<StatisticsBlock title={title} variant={variant} class={classValue}>
  <p class="text-2xl leading-tight font-semibold tracking-tight wrap-break-word text-black-100 dark:text-white">{value}</p>
  {description && <p class="mt-2 text-sm leading-6 text-black-75 dark:text-black-25">{description}</p>}
</StatisticsBlock>
